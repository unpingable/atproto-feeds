# Feed publisher account
FEED_PUBLISHER_HANDLE=instantinternet.news
FEED_PUBLISHER_PASSWORD=

# Trust graph source (whose follows/mutuals seed the feed)
TRUST_GRAPH_HANDLE=neutral.zone

# Bluesky service
BSKY_SERVICE=https://bsky.social

# Jetstream
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# Feed service (public URL where Bluesky can reach getFeedSkeleton)
FEED_SERVICE_HOSTNAME=
FEED_SERVICE_PORT=8100

# Ranking
RANK_INTERVAL_SECONDS=120
MAX_FEED_AGE_HOURS=24
MAX_POSTS_PER_AUTHOR_PER_PAGE=2
MAX_POSTS_PER_THREAD_PER_PAGE=3
FEED_PAGE_SIZE=30
